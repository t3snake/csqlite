[
  {
    "label": "Debug native binary",
    "build": {
      "command": "cmake",
      "args": ["--build", "./build"],
      "cwd": "$ZED_WORKTREE_ROOT",
    },
    "program": "$ZED_WORKTREE_ROOT/build/sqlite",
    "request": "launch",
    "args": [
      "superheroes.db",
      "SELECT id, name FROM superheroes WHERE eye_color = 'Pink Eyes'",
    ],
    "adapter": "CodeLLDB",
  },
]
